# WellCore Fitness — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Database
DB_HOST=wellcore-fitness_mysql-db
DB_PORT=3306
DB_NAME=wellcore_fitness
DB_USER=wellcore
DB_PASS=CHANGE_ME

# App
APP_ENV=production
UPLOAD_DIR=/var/www/html/wellcore/uploads/

# SMTP (PrivateEmail.com / Namecheap)
SMTP_HOST=mail.privateemail.com
SMTP_PORT=587
SMTP_USER=info@wellcorefitness.com
SMTP_PASS=CHANGE_ME
SMTP_FROM=info@wellcorefitness.com
SMTP_FROM_NAME=WellCore Fitness

# Claude AI
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-opus-4-6

# AI Router (Ollama local)
AI_ROUTER_URL=http://localhost:8000
AI_ROUTER_TIMEOUT=60

# Dify RAG
DIFY_URL=http://localhost:3000
DIFY_API_KEY=

# Digital Twin
DTAI_URL=http://localhost:8001

# PayU Latam
PAYU_API_KEY=CHANGE_ME
PAYU_MERCHANT_ID=CHANGE_ME
PAYU_ACCOUNT_ID=CHANGE_ME
PAYU_TEST_MODE=true
PAYU_CURRENCY=USD

# Security
WEBHOOK_SECRET=GENERATE_WITH_openssl_rand_hex_32
